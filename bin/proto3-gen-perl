#!/usr/bin/env perl
# ABOUTME: proto3-gen-perl — AOT code generator: parse .proto files and emit one
# deterministic .pm per file under an output tree; all rendering in Proto3::Class::Codegen (§4.12).
use v5.38;
use warnings;

use Getopt::Long ();
use File::Spec ();
use File::Path ();

use Proto3::Parser;
use Proto3::Class::Codegen;

# Parse CLI: --include (repeatable), --output, --package-prefix, then the .proto
# files to generate. parse_with_imports follows imports for resolution, but only
# the explicitly-named files are emitted.
sub run (@argv) {
    my @include;
    my $output;
    my $prefix;

    my $parser = Getopt::Long::Parser->new;
    $parser->getoptionsfromarray(
        \@argv,
        'include=s'        => \@include,
        'output=s'         => \$output,
        'package-prefix=s' => \$prefix,
    ) or die "usage: proto3-gen-perl --include DIR --output DIR "
        . "[--package-prefix PREFIX] FILE.proto ...\n";

    die "proto3-gen-perl: --output is required\n" unless defined $output;
    die "proto3-gen-perl: at least one .proto file is required\n"
        unless @argv;
    @include = ('.') unless @include;

    my $proto_parser = Proto3::Parser->new( include_paths => \@include );

    for my $rel (@argv) {
        my $schema = $proto_parser->parse_with_imports($rel);
        $schema->resolve;

        # The Schema::File for this exact requested path (by basename match on
        # the file's recorded name).
        my $file = _file_for( $schema, $rel )
            or die "proto3-gen-perl: parsed schema has no file named $rel\n";

        my $source = Proto3::Class::Codegen::render_file( $schema, $file, $prefix );
        my $rel_pm = Proto3::Class::Codegen::output_path( $file, $prefix );
        my $abs_pm = File::Spec->catfile( $output, $rel_pm );

        my $dir = ( File::Spec->splitpath($abs_pm) )[1];
        File::Path::make_path($dir) if length $dir;

        open my $fh, '>', $abs_pm
            or die "proto3-gen-perl: cannot write $abs_pm: $!\n";
        print {$fh} $source;
        close $fh;

        say "wrote $abs_pm";
    }

    return 0;
}

# Find the Schema::File whose recorded name matches $rel (the relative path the
# user requested). parse_with_imports records each file under the path used to
# load it, so an exact match suffices.
sub _file_for ( $schema, $rel ) {
    for my $file ( @{ $schema->files } ) {
        return $file if $file->name eq $rel;
    }
    return undef;
}

exit run(@ARGV) unless caller;

1;

__END__

=head1 NAME

proto3-gen-perl - ahead-of-time proto3 code generator

=head1 SYNOPSIS

    proto3-gen-perl \
        --include /path/to/protos \
        --output  /path/to/lib \
        --package-prefix T::Api \
        temporal/api/common/v1/message.proto \
        temporal/api/failure/v1/message.proto

    # Writes lib/T/Api/Common/V1/Message.pm (one .pm per .proto file).

=head1 DESCRIPTION

Reads one or more C<.proto> files and emits a Perl C<.pm> for each, under the
C<--output> directory. Imports are followed (for type resolution) via
L<Proto3::Parser/parse_with_imports>, but only the explicitly-named files are
emitted.

Protobuf packages map to Perl namespaces via C<--package-prefix>: each protobuf
path component is PascalCased and the prefix replaces the leading components, so
C<temporal.api.common.v1> under prefix C<T::Api> becomes C<T::Api::Common::V1>.

The emitted classes match what L<Proto3::Class::Generator> builds at runtime —
they share the same build path, so the accessor/codec contract cannot drift. The
generated modules depend only on the schema, codec, and WKT layers; they carry
B<no> parser or descriptor-set dependency. Output is deterministic: regenerating
an unchanged C<.proto> is byte-identical.

=head1 OPTIONS

=over 4

=item C<--include DIR>

An include-path root to search for the named files and their imports. Repeatable;
first match wins. Defaults to the current directory.

=item C<--output DIR>

The output directory under which the C<.pm> tree is written. Required.

=item C<--package-prefix PREFIX>

The Perl namespace prefix that replaces the leading protobuf package components.
Optional; without it, every component is PascalCased verbatim.

=back

